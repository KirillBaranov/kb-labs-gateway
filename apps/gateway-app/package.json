{
  "name": "@kb-labs/gateway-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run -c ../../vitest.config.ts",
    "test:watch": "vitest -c ../../vitest.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/http-proxy": "^11.4.1",
    "@fastify/websocket": "^11.0.1",
    "@kb-labs/core-config": "workspace:*",
    "@kb-labs/core-platform": "workspace:*",
    "@kb-labs/core-runtime": "workspace:*",
    "@kb-labs/core-sys": "workspace:*",
    "@kb-labs/gateway-contracts": "workspace:*",
    "@kb-labs/gateway-core": "workspace:*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../kb-labs-devkit",
    "tsx": "^4.20.5",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4",
    "ws": "^8.18.3"
  }
}
